# Atlas V0.5 — env var names only, per ADR-012 §Locality.
# Copy to `.env` and fill in dev values. `.env` is gitignored.
# Every variable here MUST also be declared in backend/src/atlas/config.py.

# ── Environment ───────────────────────────────────────────────────────────
ATLAS_ENV=dev

# ── Postgres (docker-compose default user/db) ─────────────────────────────
ATLAS_POSTGRES_USER=atlas
ATLAS_POSTGRES_PASSWORD=atlas_dev_password
ATLAS_POSTGRES_DB=atlas
ATLAS_DATABASE_URL=postgresql+asyncpg://atlas:atlas_dev_password@localhost:5432/atlas

# ── HTTP ──────────────────────────────────────────────────────────────────
ATLAS_HTTP_HOST=0.0.0.0
ATLAS_HTTP_PORT=8000

# ── Identity (required from Day 3) ────────────────────────────────────────
# Both must be >= 32 chars. Generate with: openssl rand -hex 32
# NEVER commit real values; docker-compose sets dev defaults for local runs.
ATLAS_JWT_SIGNING_KEY=
ATLAS_OTP_PEPPER=
ATLAS_SESSION_TTL_HOURS=8

# ── Later weeks (leave blank until wired) ─────────────────────────────────
# ATLAS_PAYSTACK_SECRET_KEY=
# ATLAS_BVN_PEPPER=
# ATLAS_SENTRY_DSN=

# ── Admin superadmin bootstrap (Day 5) ────────────────────────────────────
# Consumed by infrastructure/scripts/bootstrap_superadmin.py.
# Password must be >= 12 chars. Change these for anything but a throwaway
# demo environment.
ATLAS_SUPERADMIN_EMAIL=adaobi.ibe@atlas.dev
ATLAS_SUPERADMIN_PASSWORD=
